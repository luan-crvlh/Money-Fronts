{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões padrão da janela principal do Money Fronts",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/app-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
